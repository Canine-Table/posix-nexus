_start:
    xor     rax, rax          ; counter = 0
    mov     rbx, 100          ; limit = 100

loop:
    ; convert rax to ASCII
    mov     rcx, rsp
    sub     rsp, 32
    mov     rdi, rax
    mov     rsi, rcx
    call    itoa              ; write ASCII digits to buffer

    ; write(1, buffer, len)
    mov     rax, 1            ; syscall: write
    mov     rdi, 1            ; fd = stdout
    mov     rsi, rcx          ; buffer
    mov     rdx, r8           ; length returned by itoa
    syscall

    add     rsp, 32           ; restore stack

    inc     rax               ; counter++
    cmp     rax, rbx          ; reached 100?
    jne     loop              ; if not, continue

    ; exit(0)
    mov     rax, 60
    xor     rdi, rdi
    syscall

