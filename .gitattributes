########################################
## LaTeX
########################################
*.tex linguist-language=TeX
*.sty linguist-language=TeX
*.cls linguist-language=TeX

########################################
## AWK
########################################
*.awk linguist-language=Awk

########################################
## Shell / POSIX scripts
########################################
*.sh  linguist-language=Shell
*.sed linguist-language=Sed

########################################
## VimL
########################################
*.vim linguist-language=Vim

########################################
## C / C-like
########################################
*.c   linguist-language=C
*.h   linguist-language=C
*.bc  linguist-language=C

########################################
## Assembly
########################################
*.asm linguist-language=Assembly
*.s   linguist-language=Assembly
*.S   linguist-language=Assembly

########################################
## Lua
########################################
*.lua linguist-language=Lua

########################################
## Python
########################################
*.py linguist-language=Python

########################################
## Ignore XML and CSS as languages
########################################
*.xml linguist-vendored
*.html linguist-vendored
*.xhtml linguist-vendored
*.svg linguist-vendored
*.css linguist-vendored

########################################
## Vendored / non-source directories
########################################
test/** linguist-vendored

